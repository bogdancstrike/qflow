# ====================================================
# AI Flow Orchestrator — Local Development
# ====================================================

# Application
DEV_MODE=true
LOG_LEVEL=DEBUG
SECRET_KEY=dev-secret-key

# ====================================================
# Kafka
# ====================================================
WORKER_NAME=ai-flow-orchestrator
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_TASK_TOPIC_IN=flow.tasks.in
KAFKA_TASK_TOPIC_OUT=flow.tasks.out
KAFKA_DLQ_TOPIC=flow.tasks.dlq
KAFKA_COMMIT_STRATEGY=before
KAFKA_POLL_TIMEOUT_MS=1
KAFKA_POLL_MAX_RECORDS=200
KAFKA_IDLE_SLEEP_SEC=0
KAFKA_COMMIT_TICK_SEC=0.2
KAFKA_MAX_JOBS_PER_TP_PER_TICK=20
ERROR_TOPIC=error_topic
# ====================================================
# PostgreSQL
# ====================================================
DATABASE_URL=postgresql://qf:qf@localhost:5432/ai_flow

# ====================================================
# Redis
# ====================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5.0
REDIS_CONNECT_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true

# ====================================================
# Tracing (Jaeger via OTLP)
# ====================================================
ENABLE_TRACING=True
QSINT_OTLP_ENDPOINT=http://localhost:4317

# ====================================================
# AI Service URLs (used in flow definitions via {{env.AI_*}})
# ====================================================
AI_SERVICE_URL=http://localhost:8000
AI_STT_URL=http://localhost:8001
AI_STT_TOKEN=dev-token
AI_NER_URL=http://localhost:8002
AI_TRANSLATE_URL=http://localhost:8003
AI_LANGDETECT_URL=http://localhost:8004
AI_SENTIMENT_URL=http://localhost:8005
AI_SUMMARY_URL=http://localhost:8006
AI_TAXONOMY_URL=http://localhost:8007

# ====================================================
# File uploads
# ====================================================
UPLOAD_DIR=/tmp/uploads

# ====================================================
# Executor limits
# ====================================================
MAX_LOOP_ITERATIONS=100
FORK_JOIN_MAX_WORKERS=4
MAX_SUB_WORKFLOW_DEPTH=10

# ====================================================
# API
# ====================================================
API_PORT=5000

# ====================================================
# QF Framework
# ====================================================
DISABLE_SECURITY=True
DISABLE_KAFKA=false
