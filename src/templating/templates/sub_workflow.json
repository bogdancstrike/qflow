{
  "primitive": "SUB_WORKFLOW",
  "name": "Sub-Workflow",
  "description": "Invokes another registered flow definition as a child workflow. Promotes reuse — e.g., a text_to_ner flow can be reused inside video_to_ner after the STT step.",
  "schema": {
    "task_ref": {"type": "string", "required": true},
    "type": {"type": "string", "const": "SUB_WORKFLOW", "required": true},
    "sub_workflow": {
      "type": "object",
      "required": true,
      "properties": {
        "name": {"type": "string", "required": true, "description": "Flow ID to invoke"},
        "version": {"type": "integer", "default": 1}
      }
    },
    "input_parameters": {
      "type": "object",
      "description": "Input passed to the sub-workflow"
    }
  },
  "examples": [
    {
      "task_ref": "run_text_analysis",
      "type": "SUB_WORKFLOW",
      "sub_workflow": {"name": "flow_text_to_ner", "version": 1},
      "input_parameters": {
        "text": "${steps.stt.output.text}"
      }
    }
  ]
}
