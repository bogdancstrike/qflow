{
  "primitive": "TRANSFORM",
  "name": "Data Transform",
  "description": "Evaluates a lightweight expression to reshape, extract, or combine data without making any external call. Replaces the need for trivial glue microservices.",
  "schema": {
    "task_ref": {"type": "string", "required": true},
    "type": {"type": "string", "const": "TRANSFORM", "required": true},
    "input_parameters": {
      "type": "object",
      "required": true,
      "description": "Input data gathered from prior steps via interpolation"
    },
    "expression": {
      "description": "String (JSONPath extract from inputs) or dict (template to build output). If omitted, resolved input_parameters are the output."
    }
  },
  "examples": [
    {
      "description": "Extract a single field",
      "task_ref": "get_text",
      "type": "TRANSFORM",
      "input_parameters": {"text": "${steps.stt.output.text}"},
      "expression": "$.text"
    },
    {
      "description": "Merge results from parallel branches",
      "task_ref": "merge_results",
      "type": "TRANSFORM",
      "input_parameters": {
        "entities": "${steps.ner_branch.output.entities}",
        "sentiment": "${steps.sentiment_branch.output.score}",
        "text": "${workflow.variables.processed_text}"
      },
      "expression": {
        "combined": {
          "entities": "$.entities",
          "sentiment": "$.sentiment",
          "text": "$.text",
          "analysis_complete": true
        }
      }
    }
  ]
}
