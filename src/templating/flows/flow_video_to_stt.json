{
  "flow_id": "flow_video_to_stt",
  "name": "Video to Speech-to-Text",
  "version": 1,
  "description": "Extracts text from a video file using speech-to-text transcription.",
  "input_schema": {
    "type": "object",
    "required": ["file_path"],
    "properties": {
      "file_path": {
        "type": "string",
        "description": "Path to the video or audio file to transcribe"
      }
    }
  },
  "output_parameters": {
    "text": "{{steps.stt.output.text}}",
    "language": "{{steps.stt.output.language}}"
  },
  "tasks": [
    {
      "task_ref": "log_start",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Starting video-to-STT flow for file: {{workflow.input.file_path}}"
      }
    },
    {
      "task_ref": "stt",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_STT_URL}}/transcribe",
          "body": {
            "file_path": "{{workflow.input.file_path}}"
          },
          "timeout_seconds": 600
        }
      },
      "output_mapping": {
        "text": "$.response.body.text",
        "language": "$.response.body.language"
      },
      "mock_response": {
        "text": "Hello, this is a sample transcription from the video file. The quick brown fox jumps over the lazy dog.",
        "language": "en"
      }
    },
    {
      "task_ref": "log_end",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Video-to-STT flow completed. Transcribed text length: {{steps.stt.output.text}}"
      }
    }
  ]
}
