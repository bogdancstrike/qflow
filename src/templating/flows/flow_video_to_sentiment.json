{
  "flow_id": "flow_video_to_sentiment",
  "name": "Video to Sentiment Analysis",
  "version": 1,
  "description": "Transcribes video, detects language, translates if needed, and performs sentiment analysis.",
  "input_schema": {
    "type": "object",
    "required": ["file_path"],
    "properties": {
      "file_path": {
        "type": "string",
        "description": "Path to the video or audio file to analyze"
      }
    }
  },
  "output_parameters": {
    "sentiment": "{{steps.sentiment.output.sentiment}}",
    "score": "{{steps.sentiment.output.score}}",
    "language_detected": "{{steps.language_detect.output.language}}"
  },
  "tasks": [
    {
      "task_ref": "log_start",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Starting video-to-sentiment flow for file: {{workflow.input.file_path}}"
      }
    },
    {
      "task_ref": "stt",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_STT_URL}}/transcribe",
          "body": {
            "file_path": "{{workflow.input.file_path}}"
          },
          "timeout_seconds": 600
        }
      },
      "output_mapping": {
        "text": "$.response.body.text",
        "language": "$.response.body.language"
      },
      "mock_response": {
        "text": "Ce produit est absolument fantastique. Je suis tres satisfait de mon achat et je le recommande vivement.",
        "language": "fr"
      }
    },
    {
      "task_ref": "language_detect",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_SERVICE_URL}}/detect_language",
          "body": {
            "text": "{{steps.stt.output.text}}"
          },
          "timeout_seconds": 30
        }
      },
      "output_mapping": {
        "language": "$.response.body.language",
        "text": "$.response.body.text"
      },
      "mock_response": {
        "language": "fr",
        "text": "Ce produit est absolument fantastique. Je suis tres satisfait de mon achat et je le recommande vivement."
      }
    },
    {
      "task_ref": "check_language",
      "type": "SWITCH",
      "expression": "{{steps.language_detect.output.language}}",
      "decision_cases": {
        "en": [
          {
            "task_ref": "set_en_text",
            "type": "SET_VARIABLE",
            "input_parameters": {
              "processed_text": "{{steps.language_detect.output.text}}"
            }
          }
        ]
      },
      "default_case": [
        {
          "task_ref": "translate_to_en",
          "type": "HTTP",
          "input_parameters": {
            "http_request": {
              "method": "POST",
              "url": "{{env.AI_SERVICE_URL}}/translate",
              "body": {
                "text": "{{steps.language_detect.output.text}}",
                "source_language": "{{steps.language_detect.output.language}}",
                "target_language": "en"
              },
              "timeout_seconds": 60
            }
          },
          "output_mapping": {
            "text": "$.response.body.text"
          },
          "mock_response": {
            "text": "This product is absolutely fantastic. I am very satisfied with my purchase and I highly recommend it."
          }
        },
        {
          "task_ref": "set_translated_text",
          "type": "SET_VARIABLE",
          "input_parameters": {
            "processed_text": "{{steps.translate_to_en.output.text}}"
          }
        }
      ]
    },
    {
      "task_ref": "sentiment",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_SERVICE_URL}}/sentiment",
          "body": {
            "text": "{{workflow.variables.processed_text}}"
          },
          "timeout_seconds": 60
        }
      },
      "output_mapping": {
        "sentiment": "$.response.body.sentiment",
        "score": "$.response.body.score"
      },
      "mock_response": {
        "sentiment": "positive",
        "score": 0.94
      }
    },
    {
      "task_ref": "log_end",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Video-to-sentiment flow completed. Sentiment: {{steps.sentiment.output.sentiment}}, Score: {{steps.sentiment.output.score}}"
      }
    }
  ]
}
