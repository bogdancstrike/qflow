{
  "flow_id": "flow_youtube_to_ner",
  "name": "YouTube to Named Entity Recognition",
  "version": 1,
  "description": "Downloads a YouTube video, transcribes it, detects language, translates if needed, and extracts named entities.",
  "input_schema": {
    "type": "object",
    "required": ["youtube_url"],
    "properties": {
      "youtube_url": {
        "type": "string",
        "description": "The YouTube video URL to download and analyze"
      }
    }
  },
  "output_parameters": {
    "entities": "{{steps.ner.output.entities}}",
    "language_detected": "{{steps.language_detect.output.language}}"
  },
  "tasks": [
    {
      "task_ref": "log_start",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Starting YouTube-to-NER flow for URL: {{workflow.input.youtube_url}}"
      }
    },
    {
      "task_ref": "youtube_download",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_STT_URL}}/download_youtube",
          "body": {
            "url": "{{workflow.input.youtube_url}}"
          },
          "timeout_seconds": 300
        }
      },
      "output_mapping": {
        "file_path": "$.response.body.file_path"
      },
      "mock_response": {
        "file_path": "/tmp/uploads/youtube_downloaded.mp4"
      }
    },
    {
      "task_ref": "stt",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_STT_URL}}/transcribe",
          "body": {
            "file_path": "{{steps.youtube_download.output.file_path}}"
          },
          "timeout_seconds": 600
        }
      },
      "output_mapping": {
        "text": "$.response.body.text",
        "language": "$.response.body.language"
      },
      "mock_response": {
        "text": "Presidente Lula visitou a sede da Petrobras no Rio de Janeiro para discutir o futuro energetico do Brasil.",
        "language": "pt"
      }
    },
    {
      "task_ref": "language_detect",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_SERVICE_URL}}/detect_language",
          "body": {
            "text": "{{steps.stt.output.text}}"
          },
          "timeout_seconds": 30
        }
      },
      "output_mapping": {
        "language": "$.response.body.language",
        "text": "$.response.body.text"
      },
      "mock_response": {
        "language": "pt",
        "text": "Presidente Lula visitou a sede da Petrobras no Rio de Janeiro para discutir o futuro energetico do Brasil."
      }
    },
    {
      "task_ref": "check_language",
      "type": "SWITCH",
      "expression": "{{steps.language_detect.output.language}}",
      "decision_cases": {
        "en": [
          {
            "task_ref": "set_en_text",
            "type": "SET_VARIABLE",
            "input_parameters": {
              "processed_text": "{{steps.language_detect.output.text}}"
            }
          }
        ]
      },
      "default_case": [
        {
          "task_ref": "translate_to_en",
          "type": "HTTP",
          "input_parameters": {
            "http_request": {
              "method": "POST",
              "url": "{{env.AI_SERVICE_URL}}/translate",
              "body": {
                "text": "{{steps.language_detect.output.text}}",
                "source_language": "{{steps.language_detect.output.language}}",
                "target_language": "en"
              },
              "timeout_seconds": 60
            }
          },
          "output_mapping": {
            "text": "$.response.body.text"
          },
          "mock_response": {
            "text": "President Lula visited the Petrobras headquarters in Rio de Janeiro to discuss the energy future of Brazil."
          }
        },
        {
          "task_ref": "set_translated_text",
          "type": "SET_VARIABLE",
          "input_parameters": {
            "processed_text": "{{steps.translate_to_en.output.text}}"
          }
        }
      ]
    },
    {
      "task_ref": "ner",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_SERVICE_URL}}/ner",
          "body": {
            "text": "{{workflow.variables.processed_text}}"
          },
          "timeout_seconds": 60
        }
      },
      "output_mapping": {
        "entities": "$.response.body.entities"
      },
      "mock_response": {
        "entities": [
          {"text": "Lula", "type": "PERSON", "start": 10, "end": 14},
          {"text": "Petrobras", "type": "ORGANIZATION", "start": 27, "end": 36},
          {"text": "Rio de Janeiro", "type": "LOCATION", "start": 54, "end": 68},
          {"text": "Brazil", "type": "LOCATION", "start": 100, "end": 106}
        ]
      }
    },
    {
      "task_ref": "log_end",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "YouTube-to-NER flow completed. Detected language: {{steps.language_detect.output.language}}"
      }
    }
  ]
}
