{
  "flow_id": "flow_text_to_sentiment",
  "name": "Text to Sentiment Analysis",
  "version": 1,
  "description": "Detects language of input text, translates if needed, and performs sentiment analysis.",
  "input_schema": {
    "type": "object",
    "required": ["text"],
    "properties": {
      "text": {
        "type": "string",
        "description": "The text to analyze for sentiment"
      }
    }
  },
  "output_parameters": {
    "sentiment": "{{steps.sentiment.output.sentiment}}",
    "score": "{{steps.sentiment.output.score}}",
    "language_detected": "{{steps.language_detect.output.language}}"
  },
  "tasks": [
    {
      "task_ref": "log_start",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Starting text-to-sentiment flow"
      }
    },
    {
      "task_ref": "language_detect",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_SERVICE_URL}}/detect_language",
          "body": {
            "text": "{{workflow.input.text}}"
          },
          "timeout_seconds": 30
        }
      },
      "output_mapping": {
        "language": "$.response.body.language",
        "text": "$.response.body.text"
      },
      "mock_response": {
        "language": "pt",
        "text": "Este servico e horrivel. Nunca mais volto a usar. Perdi muito tempo e dinheiro."
      }
    },
    {
      "task_ref": "check_language",
      "type": "SWITCH",
      "expression": "{{steps.language_detect.output.language}}",
      "decision_cases": {
        "en": [
          {
            "task_ref": "set_en_text",
            "type": "SET_VARIABLE",
            "input_parameters": {
              "processed_text": "{{steps.language_detect.output.text}}"
            }
          }
        ]
      },
      "default_case": [
        {
          "task_ref": "translate_to_en",
          "type": "HTTP",
          "input_parameters": {
            "http_request": {
              "method": "POST",
              "url": "{{env.AI_SERVICE_URL}}/translate",
              "body": {
                "text": "{{steps.language_detect.output.text}}",
                "source_language": "{{steps.language_detect.output.language}}",
                "target_language": "en"
              },
              "timeout_seconds": 60
            }
          },
          "output_mapping": {
            "text": "$.response.body.text"
          },
          "mock_response": {
            "text": "This service is horrible. I will never use it again. I wasted a lot of time and money."
          }
        },
        {
          "task_ref": "set_translated_text",
          "type": "SET_VARIABLE",
          "input_parameters": {
            "processed_text": "{{steps.translate_to_en.output.text}}"
          }
        }
      ]
    },
    {
      "task_ref": "sentiment",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_SERVICE_URL}}/sentiment",
          "body": {
            "text": "{{workflow.variables.processed_text}}"
          },
          "timeout_seconds": 60
        }
      },
      "output_mapping": {
        "sentiment": "$.response.body.sentiment",
        "score": "$.response.body.score"
      },
      "mock_response": {
        "sentiment": "negative",
        "score": -0.87
      }
    },
    {
      "task_ref": "log_end",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Text-to-sentiment flow completed. Sentiment: {{steps.sentiment.output.sentiment}}, Score: {{steps.sentiment.output.score}}"
      }
    }
  ]
}
