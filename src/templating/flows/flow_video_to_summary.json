{
  "flow_id": "flow_video_to_summary",
  "name": "Video to Summary",
  "version": 1,
  "description": "Transcribes video, detects language, translates if needed, and generates a summary.",
  "input_schema": {
    "type": "object",
    "required": ["file_path"],
    "properties": {
      "file_path": {
        "type": "string",
        "description": "Path to the video or audio file to summarize"
      }
    }
  },
  "output_parameters": {
    "summary": "{{steps.summary.output.summary}}",
    "language_detected": "{{steps.language_detect.output.language}}"
  },
  "tasks": [
    {
      "task_ref": "log_start",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Starting video-to-summary flow for file: {{workflow.input.file_path}}"
      }
    },
    {
      "task_ref": "stt",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_STT_URL}}/transcribe",
          "body": {
            "file_path": "{{workflow.input.file_path}}"
          },
          "timeout_seconds": 600
        }
      },
      "output_mapping": {
        "text": "$.response.body.text",
        "language": "$.response.body.language"
      },
      "mock_response": {
        "text": "En la reunion de hoy discutimos los avances del proyecto. El equipo de desarrollo completo la primera fase. Se identificaron tres problemas principales que requieren atencion inmediata. La proxima reunion sera el viernes.",
        "language": "es"
      }
    },
    {
      "task_ref": "language_detect",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_SERVICE_URL}}/detect_language",
          "body": {
            "text": "{{steps.stt.output.text}}"
          },
          "timeout_seconds": 30
        }
      },
      "output_mapping": {
        "language": "$.response.body.language",
        "text": "$.response.body.text"
      },
      "mock_response": {
        "language": "es",
        "text": "En la reunion de hoy discutimos los avances del proyecto. El equipo de desarrollo completo la primera fase. Se identificaron tres problemas principales que requieren atencion inmediata. La proxima reunion sera el viernes."
      }
    },
    {
      "task_ref": "check_language",
      "type": "SWITCH",
      "expression": "{{steps.language_detect.output.language}}",
      "decision_cases": {
        "en": [
          {
            "task_ref": "set_en_text",
            "type": "SET_VARIABLE",
            "input_parameters": {
              "processed_text": "{{steps.language_detect.output.text}}"
            }
          }
        ]
      },
      "default_case": [
        {
          "task_ref": "translate_to_en",
          "type": "HTTP",
          "input_parameters": {
            "http_request": {
              "method": "POST",
              "url": "{{env.AI_SERVICE_URL}}/translate",
              "body": {
                "text": "{{steps.language_detect.output.text}}",
                "source_language": "{{steps.language_detect.output.language}}",
                "target_language": "en"
              },
              "timeout_seconds": 60
            }
          },
          "output_mapping": {
            "text": "$.response.body.text"
          },
          "mock_response": {
            "text": "In today's meeting we discussed the project's progress. The development team completed the first phase. Three main problems were identified that require immediate attention. The next meeting will be on Friday."
          }
        },
        {
          "task_ref": "set_translated_text",
          "type": "SET_VARIABLE",
          "input_parameters": {
            "processed_text": "{{steps.translate_to_en.output.text}}"
          }
        }
      ]
    },
    {
      "task_ref": "summary",
      "type": "HTTP",
      "input_parameters": {
        "http_request": {
          "method": "POST",
          "url": "{{env.AI_SERVICE_URL}}/summarize",
          "body": {
            "text": "{{workflow.variables.processed_text}}"
          },
          "timeout_seconds": 120
        }
      },
      "output_mapping": {
        "summary": "$.response.body.summary"
      },
      "mock_response": {
        "summary": "Meeting covered project progress: Phase 1 completed by development team. Three critical issues identified requiring immediate action. Next meeting scheduled for Friday."
      }
    },
    {
      "task_ref": "log_end",
      "type": "LOG",
      "input_parameters": {
        "level": "INFO",
        "message": "Video-to-summary flow completed. Language detected: {{steps.language_detect.output.language}}"
      }
    }
  ]
}
